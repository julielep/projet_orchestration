# -------------------------
# CONFIGURATION DE LA BASE DE DONNEES
# -------------------------
# Exemple pour SQLite (fichier local)
DATABASE_URL=sqlite:///./app.db

# Si tu veux utiliser PostgreSQL plus tard, tu pourrais faire :
# DATABASE_URL=postgresql://user:password@localhost:5432/nomdb

# -------------------------
# CONFIGURATION DE L'API
# -------------------------
# Port sur lequel tourne FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# -------------------------
# CONFIGURATION DE STREAMLIT
# -------------------------
# Port Streamlit
STREAMLIT_PORT=8501

# URL de l'API que Streamlit va consommer
STREAMLIT_API_URL=http://localhost:8000

# -------------------------
# AUTRES VARIABLES SECRETS (exemple)
# -------------------------
# Clés API, tokens, etc.
# SECRET_KEY=ma_cle_secrete