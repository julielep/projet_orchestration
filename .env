# --- CONFIGURATION DB ---
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb

# --- CONFIGURATION API / SQLALCHEMY ---
# Utilisation du nom de service 'database' défini dans le docker-compose
DATABASE_URL=postgresql://myuser:mypassword@database:5432/mydb

# --- CONFIGURATION FRONTEND ---
# Streamlit doit pointer vers le nom du service 'api'
API_URL=http://api:8000