# # Base de données SQLite locale
# DATABASE_URL=sqlite:///./app.db #Local -> serveur distant pour conteneur

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501
STREAMLIT_API_URL=http://localhost:8000


# --- CONFIGURATION DB ---
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb

# --- CONFIGURATION API / SQLALCHEMY ---
# Note : Ici on utilise "database" car c'est le nom du service dans docker-compose
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@database:5432/${POSTGRES_DB}

